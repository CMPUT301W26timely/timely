<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/surface"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/border">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="18dp">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_role_icon_blue"
            android:backgroundTint="@color/accentTint">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_notifications"
                app:tint="@color/primaryAccent"
                android:contentDescription="@string/nav_notifications" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNotificationStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textSize="9sp"
                android:fontFamily="sans-serif-medium"
                android:textStyle="bold"
                android:textColor="@color/primaryMid"
                android:textAllCaps="true"
                android:background="@drawable/bg_pill_green" />

            <TextView
                android:id="@+id/tvNotificationMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:textSize="14sp"
                android:textColor="@color/textPrimary" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivNotifChevron"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@android:drawable/ic_media_next"
            app:tint="@color/textMuted"
            android:contentDescription="@string/decorative_image" />
    </LinearLayout>

    <!-- US 01.05.07: Accept / Decline for private waiting-list invitations.
         Visible only when notification type == "privateInvite". -->
    <LinearLayout
        android:id="@+id/layoutNotifPrivateActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp"
        android:weightSum="2"
        android:visibility="gone">

        <Button
            android:id="@+id/btnNotifDecline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:text="Decline"
            android:textColor="#D32F2F"
            style="?attr/materialButtonOutlinedStyle" />

        <Button
            android:id="@+id/btnNotifAccept"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:backgroundTint="#4CAF50"
            android:text="Accept"
            android:textColor="#FFFFFF" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>