<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_view_comments.xml
    Dialog layout used by ViewCommentsFragment to show a filtered comment list.
    Displays either "My Comments" (organizer) or "Entrant Comments" depending
    on the mode argument passed via ViewCommentsFragment.newInstance().
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/surface"
    android:paddingBottom="18dp">

    <!-- Dialog title -->
    <TextView
        android:id="@+id/tvViewCommentsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/comments_title"
        android:textSize="20sp"
        android:fontFamily="serif"
        android:textStyle="bold"
        android:textColor="@color/textPrimary"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="22dp"
        android:paddingBottom="14dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border" />

    <!-- Empty state label -->
    <TextView
        android:id="@+id/tvViewCommentsEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/comments_empty"
        android:textSize="14sp"
        android:textColor="@color/textMuted"
        android:gravity="center"
        android:padding="28dp"
        android:visibility="gone" />

    <!-- Comment list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvViewComments"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="400dp"
        android:nestedScrollingEnabled="true"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="8dp" />

    <!-- Close button -->
    <Button
        android:id="@+id/btnViewCommentsClose"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="18dp"
        android:text="@string/comments_close"
        android:textSize="14sp"
        android:textColor="@color/white"
        android:backgroundTint="@color/primaryAccent"
        android:paddingStart="20dp"
        android:paddingEnd="20dp" />

</LinearLayout>
