<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout for InviteEntrantsActivity.
    US 02.01.03 — Organizer invites specific entrants to a private event's waiting list
                  by searching via name, phone number and/or email.
-->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pageBg"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="40dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnInviteBack"
                style="@style/Widget.CodeBase.BackButton"
                android:contentDescription="@string/invite_back_desc" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:text="@string/invite_screen_title"
                style="@style/TextAppearance.CodeBase.PageTitleCompact" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/invite_private_badge"
            android:textSize="12sp"
            android:textColor="@color/primaryAccent"
            android:background="@drawable/bg_pill_green"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/invite_direct_title"
            android:textColor="@color/textPrimary"
            android:textSize="30sp"
            android:textStyle="bold"
            android:fontFamily="serif" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/invite_direct_subtitle"
            android:textColor="@color/textSecondary"
            android:textSize="15sp"
            android:lineSpacingExtra="2dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/border"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/TextAppearance.CodeBase.Eyebrow"
                    android:text="@string/invite_lookup_label"
                    android:textAllCaps="true" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutInviteName"
                    style="@style/Widget.CodeBase.TextInputLayout.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/invite_name_label"
                    app:boxBackgroundColor="@color/surface"
                    app:boxCornerRadiusBottomEnd="18dp"
                    app:boxCornerRadiusBottomStart="18dp"
                    app:boxCornerRadiusTopEnd="18dp"
                    app:boxCornerRadiusTopStart="18dp"
                    app:boxStrokeColor="@color/primaryAccent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etInviteName"
                        style="@style/Widget.CodeBase.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="58dp"
                        android:inputType="textPersonName"
                        android:textColor="@color/textPrimary"
                        android:textColorHint="@color/textMuted" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutInviteEmail"
                    style="@style/Widget.CodeBase.TextInputLayout.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/invite_email_exact_label"
                    app:boxBackgroundColor="@color/surface"
                    app:boxCornerRadiusBottomEnd="18dp"
                    app:boxCornerRadiusBottomStart="18dp"
                    app:boxCornerRadiusTopEnd="18dp"
                    app:boxCornerRadiusTopStart="18dp"
                    app:boxStrokeColor="@color/primaryAccent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etInviteEmail"
                        style="@style/Widget.CodeBase.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="58dp"
                        android:inputType="textEmailAddress"
                        android:importantForAutofill="yes"
                        android:autofillHints="emailAddress"
                        android:textColor="@color/textPrimary"
                        android:textColorHint="@color/textMuted" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/inputLayoutInvitePhone"
                    style="@style/Widget.CodeBase.TextInputLayout.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="@string/invite_phone_exact_label"
                    app:boxBackgroundColor="@color/surface"
                    app:boxCornerRadiusBottomEnd="18dp"
                    app:boxCornerRadiusBottomStart="18dp"
                    app:boxCornerRadiusTopEnd="18dp"
                    app:boxCornerRadiusTopStart="18dp"
                    app:boxStrokeColor="@color/primaryAccent">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etInvitePhone"
                        style="@style/Widget.CodeBase.TextInputEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="58dp"
                        android:inputType="phone"
                        android:importantForAutofill="yes"
                        android:autofillHints="phone"
                        android:textColor="@color/textPrimary"
                        android:textColorHint="@color/textMuted" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:id="@+id/tvInviteLoading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/invite_loading"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvInviteStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/btnInviteByContact"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="@string/invite_search_button"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvInviteResultsLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    style="@style/TextAppearance.CodeBase.Eyebrow"
                    android:text="@string/invite_results_label"
                    android:textAllCaps="true"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvInviteEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="@string/invite_empty"
                    android:textColor="@color/textSecondary"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvInviteResults"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
