<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout for InviteEntrantsActivity.
    US 02.01.03 — Organizer invites specific entrants to a private event's waiting list
                  by searching via name, phone number and/or email.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0EDE8">

    <!-- ── TOP BAR ──────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="36dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:background="#F0EDE8">

        <Button
            android:id="@+id/btnInviteBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="@string/invite_back_desc"
            android:textSize="20sp"
            android:textColor="#111111"
            android:background="@drawable/bg_icon_btn_light"
            android:padding="0dp"
            android:contentDescription="@string/invite_back_desc" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/invite_screen_title"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:textColor="@color/textPrimary"
            android:gravity="center"
            android:layout_marginEnd="48dp" />

    </LinearLayout>

    <!-- ── PRIVATE BADGE ─────────────────────────────────────────────────── -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="12dp"
        android:text="@string/invite_private_badge"
        android:textSize="12sp"
        android:textColor="#FFFFFF"
        android:background="#555555"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp" />

    <!-- ── SEARCH BAR ─────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/invite_search_label"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:textAllCaps="true"
            android:textColor="@color/textSecondary"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/etInviteSearch"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="@string/invite_search_hint"
            android:textSize="15sp"
            android:textColor="@color/textPrimary"
            android:textColorHint="@color/textSecondary"
            android:background="@drawable/bg_input_field"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true"
            android:autofillHints="name" />

    </LinearLayout>

    <!-- ── LOADING ────────────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvInviteLoading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/invite_loading"
        android:textSize="14sp"
        android:textColor="@color/textSecondary"
        android:gravity="center"
        android:paddingTop="40dp"
        android:visibility="gone" />

    <!-- ── COUNT LABEL ────────────────────────────────────────────────────── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/invite_results_label"
        android:textSize="11sp"
        android:letterSpacing="0.08"
        android:textAllCaps="true"
        android:textColor="@color/textSecondary"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="6dp" />

    <!-- ── EMPTY STATE ────────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvInviteEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/invite_empty"
        android:textSize="14sp"
        android:textColor="@color/textSecondary"
        android:gravity="center"
        android:paddingTop="40dp"
        android:visibility="gone" />

    <!-- ── RESULTS LIST ───────────────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewInvite"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="4dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false" />

</LinearLayout>