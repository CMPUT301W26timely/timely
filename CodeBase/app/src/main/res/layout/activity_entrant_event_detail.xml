<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_entrant_event_detail.xml
    Layout for EntrantEventDetailActivity.

    Sections:
      1. Hero poster image with back button + event title overlay
      2. Scrollable event details (date, location, description)
      3. Comments section (US 01.08.01 & US 01.08.02):
           - EditText + Post button to submit a new comment
           - "View Organizer Comments" button
           - "View All Entrant Comments" button
      4. Fixed bottom bar: Drop Out / Join / Leave waiting-list buttons
      5. Co-organizer warning label
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0EDE8">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/layoutButtons"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── 1. Hero Image ──────────────────────────────────────────── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="250dp">

                <ImageView
                    android:id="@+id/ivEntrantHeroPoster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:background="#CCCCCC"
                    android:contentDescription="Event Poster" />

                <!-- Dark overlay for text legibility -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#66000000" />

                <ImageButton
                    android:id="@+id/btnEntrantBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_margin="16dp"
                    android:paddingTop="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_media_previous"
                    app:tint="#FFFFFF"
                    android:contentDescription="Back" />

                <TextView
                    android:id="@+id/tvEntrantEventTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:layout_margin="20dp"
                    android:text="Event Title"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

            </FrameLayout>

            <!-- ── 2. Event Details ───────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvEntrantEventDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:drawableStartCompat="@android:drawable/ic_menu_today"
                    android:drawablePadding="8dp"
                    android:text="Date not set"
                    android:textColor="#555555"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvEntrantEventLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:drawableStartCompat="@android:drawable/ic_menu_mylocation"
                    android:drawablePadding="8dp"
                    android:text="Location"
                    android:textColor="#555555"
                    android:textSize="16sp" />

                <!-- US 01.05.04 — show the total current waiting-list size to entrants -->
                <TextView
                    android:id="@+id/tvEntrantWaitingListCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:drawableStartCompat="@android:drawable/ic_menu_agenda"
                    android:drawablePadding="8dp"
                    android:text="Total waiting list entrants: 0"
                    android:textColor="#555555"
                    android:textSize="16sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="#DDDDDD" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About this event"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvEntrantEventDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingMultiplier="1.2"
                    android:text="Event description goes here..."
                    android:textColor="#666666"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- ── 3. Comments Section (US 01.08.01 & US 01.08.02) ───────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="20dp">

                <!-- Section divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="16dp"
                    android:background="#DDDDDD" />

                <!-- Section header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Comments"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Post comment row: input field + Post button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/etEntrantNewComment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Write a comment…"
                        android:inputType="textMultiLine|textCapSentences"
                        android:maxLines="3"
                        android:textSize="14sp"
                        android:textColor="#333333"
                        android:textColorHint="#AAAAAA"
                        android:padding="10dp"
                        android:background="@android:drawable/edit_text"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="Comment input" />

                    <!-- US 01.08.01 — Post comment button -->
                    <Button
                        android:id="@+id/btnEntrantPostComment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Post"
                        android:textColor="#FFFFFF"
                        android:backgroundTint="#4A7A4A"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />

                </LinearLayout>

                <!-- US 01.08.02 — View Organizer Comments button -->
                <Button
                    android:id="@+id/btnViewOrganizerComments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="View Organizer Comments"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#5C6BC0"
                    android:layout_marginBottom="8dp" />

                <!-- US 01.08.02 — View All Entrant Comments button -->
                <Button
                    android:id="@+id/btnViewAllEntrantComments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="View All Entrant Comments"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#5C6BC0" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ── 4. Fixed Bottom Buttons ──────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/layoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:padding="16dp">

        <!-- Drop Out Button (Full Width) — shown when enrolled -->
        <Button
            android:id="@+id/btnDropOut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#D32F2F"
            android:text="Drop out of event"
            android:textColor="#FFFFFF"
            android:visibility="gone"
            style="?android:attr/buttonBarButtonStyle" />

        <!-- Join / Leave row — shown when not enrolled -->
        <LinearLayout
            android:id="@+id/layoutJoinLeave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:weightSum="2"
            style="?android:attr/buttonBarStyle"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnLeaveWaitingList"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#D32F2F"
                    android:text="Leave waiting list"
                    android:textColor="#FFFFFF"
                    style="?android:attr/buttonBarButtonStyle" />

                <Button
                    android:id="@+id/btnJoinWaitingList"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#4CAF50"
                    android:text="Join waiting list"
                    android:textColor="#FFFFFF"
                    style="?android:attr/buttonBarButtonStyle" />

            </LinearLayout>

            <!-- Shown only when the entrant is a co-organizer for this event -->
            <TextView
                android:id="@+id/tvCoOrgWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="You are a co-organizer for this event and cannot join the waiting list."
                android:textSize="12sp"
                android:textColor="#CC3333"
                android:gravity="center"
                android:paddingTop="6dp"
                android:visibility="gone" />

        </LinearLayout>
    </FrameLayout>

    <!-- Progress indicator -->
    <ProgressBar
        android:id="@+id/entrantDetailProgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone" />

</RelativeLayout>
