<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_entrant_event_detail.xml
    Layout for EntrantEventDetailActivity.

    Sections:
      1. Hero poster image with back button + event title overlay
      2. Scrollable event details (date, location, description)
      3. Comments section (US 01.08.01 & US 01.08.02):
           - EditText + Post button to submit a new comment
           - "View Organizer Comments" button
           - "View All Entrant Comments" button
      4. Fixed bottom bar: Drop Out / Join / Leave waiting-list buttons
      5. Co-organizer warning label
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pageBg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/layoutButtons"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── 1. Hero Image ──────────────────────────────────────────── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="250dp">

                <ImageView
                    android:id="@+id/ivEntrantHeroPoster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_hero_image"
                    android:contentDescription="@string/event_poster_desc"
                    android:scaleType="centerCrop" />

                <!-- Dark overlay for text legibility -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#66000000" />

                <ImageButton
                    android:id="@+id/btnEntrantBack"
                    style="@style/Widget.CodeBase.BackButton"
                    android:layout_margin="16dp"
                    android:contentDescription="@string/back_button_desc" />

                <TextView
                    android:id="@+id/tvEntrantEventTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:layout_margin="20dp"
                    android:text="@string/untitled_event"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold" />

            </FrameLayout>

            <!-- ── 2. Event Details ───────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvEntrantEventDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:drawableStartCompat="@android:drawable/ic_menu_today"
                    android:drawablePadding="8dp"
                    android:text="@string/date_not_set"
                    android:textColor="@color/textSecondary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvEntrantEventLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:drawableStartCompat="@android:drawable/ic_menu_mylocation"
                    android:drawablePadding="8dp"
                    android:text="@string/history_location_not_set"
                    android:textColor="@color/textSecondary"
                    android:textSize="16sp" />

                <!-- US 01.05.04 — show the total current waiting-list size to entrants -->
                <TextView
                    android:id="@+id/tvEntrantWaitingListCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:drawableStartCompat="@android:drawable/ic_menu_agenda"
                    android:drawablePadding="8dp"
                    android:text="Total waiting list entrants: 0"
                    android:textColor="@color/textSecondary"
                    android:textSize="16sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="20dp"
                    android:background="@color/border" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/entrant_event_about_title"
                    android:textColor="@color/textPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvEntrantEventDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingMultiplier="1.2"
                    android:text="@string/entrant_event_description_fallback"
                    android:textColor="@color/textSecondary"
                    android:textSize="15sp" />

            </LinearLayout>

            <!-- ── 3. Comments Section (US 01.08.01 & US 01.08.02) ───────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingBottom="20dp">

                <!-- Section divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginBottom="16dp"
                    android:background="@color/border" />

                <!-- Section header -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/comments_title"
                    android:textColor="@color/textPrimary"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <!-- Post comment row: input field + Post button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/etEntrantNewComment"
                        style="@style/Widget.CodeBase.EditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="@string/entrant_event_comment_hint"
                        android:inputType="textMultiLine|textCapSentences"
                        android:maxLines="3"
                        android:textSize="14sp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@string/entrant_event_comment_hint" />

                    <!-- US 01.08.01 — Post comment button -->
                    <Button
                        android:id="@+id/btnEntrantPostComment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/entrant_event_post_comment"
                        android:textColor="@color/white"
                        android:backgroundTint="@color/primaryAccent"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />

                </LinearLayout>

                <!-- US 01.08.02 — View Organizer Comments button -->
                <Button
                    android:id="@+id/btnViewOrganizerComments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/entrant_event_view_organizer_comments"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primaryMid"
                    android:layout_marginBottom="8dp" />

                <!-- US 01.08.02 — View All Entrant Comments button -->
                <Button
                    android:id="@+id/btnViewAllEntrantComments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/entrant_event_view_all_comments"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primaryMid"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnViewLottoInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/entrant_event_view_lottery_info"
                    android:textColor="@color/white"
                    android:backgroundTint="@color/primaryMid" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ── 4. Fixed Bottom Buttons ──────────────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/layoutButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/surface"
        android:elevation="8dp"
        android:padding="16dp">

        <!-- Drop Out Button (Full Width) — shown when enrolled -->
        <Button
            android:id="@+id/btnDropOut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/historyCancelledText"
            android:text="@string/entrant_event_drop_out"
            android:textColor="@color/white"
            android:visibility="gone"
            style="?android:attr/buttonBarButtonStyle" />

        <!-- Join / Leave row — shown when not enrolled -->
        <LinearLayout
            android:id="@+id/layoutJoinLeave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:weightSum="2"
            style="?android:attr/buttonBarStyle"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnLeaveWaitingList"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/historyCancelledText"
                    android:text="@string/entrant_event_leave_waitlist"
                    android:textColor="@color/white"
                    style="?android:attr/buttonBarButtonStyle" />

                <Button
                    android:id="@+id/btnJoinWaitingList"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/primaryAccent"
                    android:text="@string/entrant_event_join_waitlist"
                    android:textColor="@color/white"
                    style="?android:attr/buttonBarButtonStyle" />

            </LinearLayout>

            <!-- Shown only when the entrant is a co-organizer for this event -->
            <TextView
                android:id="@+id/tvCoOrgWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/entrant_event_coorganizer_warning"
                android:textSize="12sp"
                android:textColor="@color/historyCancelledText"
                android:gravity="center"
                android:paddingTop="6dp"
                android:visibility="gone" />

        </LinearLayout>
    </FrameLayout>

    <!-- Progress indicator -->
    <ProgressBar
        android:id="@+id/entrantDetailProgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone" />

</RelativeLayout>
