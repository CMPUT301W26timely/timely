<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111827">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── HERO IMAGE AREA ──────────────────────────────────────────── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="300dp">

            <!-- Hero poster image — loaded from Firestore posterUrl via Glide -->
            <ImageView
                android:id="@+id/ivHeroPoster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_hero_image"
                android:contentDescription="@string/decorative_image" />

            <!-- Dark overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#99000000" />

            <!-- Top bar: back + more -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="36dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_media_previous"
                    android:background="@drawable/bg_icon_btn"
                    android:contentDescription="@string/back_button_desc" />

                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                <ProgressBar
                    android:id="@+id/detailProgressBar"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp" />

            </LinearLayout>

            <!-- Bottom of hero: status badge + title + date + location -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="bottom"
                android:padding="16dp">

                <!-- Status badge -->
                <TextView
                    android:id="@+id/tvDetailStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_status_badge_open"
                    android:layout_marginBottom="8dp" />

                <!-- Event title -->
                <TextView
                    android:id="@+id/tvDetailTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="6dp" />

                <!-- Date row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_menu_today"
                        app:tint="#AABBCC"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:id="@+id/tvDetailDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#AABBCC" />

                </LinearLayout>

                <!-- Location row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_menu_mylocation"
                        app:tint="#AABBCC"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:id="@+id/tvDetailLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#AABBCC" />

                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- ── DESCRIPTION ──────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvDetailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:textSize="13sp"
            android:textColor="#AABBCC"
            android:lineSpacingMultiplier="1.4" />

        <!-- ── CAPACITY ROW ──────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/max_capacity_label"
                    android:textSize="11sp"
                    android:textColor="#556677"
                    android:textAllCaps="true" />
                <TextView
                    android:id="@+id/tvMaxCapacity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/winners_count_label"
                    android:textSize="11sp"
                    android:textColor="#556677"
                    android:textAllCaps="true" />
                <TextView
                    android:id="@+id/tvWinnersCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />
            </LinearLayout>

        </LinearLayout>

        <!-- ── STAT CARDS ───────────────────────────────────────────────── -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:padding="16dp"
            android:useDefaultMargins="true">

            <!-- Waiting List -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="#1A2335"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:padding="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/stat_waiting_list"
                            android:textSize="11sp"
                            android:textColor="#7A8FA6"
                            android:textAllCaps="true" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_menu_my_calendar"
                            app:tint="#F0A500" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvWaitingCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Invited -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="#1A2335"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:padding="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/stat_invited"
                            android:textSize="11sp"
                            android:textColor="#7A8FA6"
                            android:textAllCaps="true" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_dialog_email"
                            app:tint="#5B9BD5" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvInvitedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Enrolled -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#1A2335"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:id="@+id/boxViewEnrolled"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/stat_enrolled"
                            android:textAllCaps="true"
                            android:textColor="#7A8FA6"
                            android:textSize="11sp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_menu_add"
                            app:tint="#2ECC71" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvEnrolledCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#FFFFFF"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Cancelled -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_marginStart="6dp"
                app:cardBackgroundColor="#1A2335"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:padding="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/stat_cancelled"
                            android:textSize="11sp"
                            android:textColor="#7A8FA6"
                            android:textAllCaps="true" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_delete"
                            app:tint="#E74C3C" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvCancelledCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </GridLayout>

        <!-- ── LOTTERY MANAGEMENT ────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_lottery_management"
            android:textSize="11sp"
            android:textColor="#556677"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="6dp" />

        <!-- Run Lottery Draw -->
        <LinearLayout
            android:id="@+id/rowRunLottery"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_row_item"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="2dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_rotate"
                app:tint="#7C6AF7"
                android:layout_marginEnd="14dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_run_lottery"
                android:textSize="15sp"
                android:textColor="#FFFFFF" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#556677" />

        </LinearLayout>

        <!-- Send Notification — US 02.07.01, 02.07.02, 02.07.03 -->
        <LinearLayout
            android:id="@+id/rowSendNotification"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_row_item"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_popup_reminder"
                app:tint="#7A8FA6"
                android:layout_marginEnd="14dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_send_notification"
                android:textSize="15sp"
                android:textColor="#FFFFFF" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#556677" />

        </LinearLayout>

        <!-- ── EVENT DATA ─────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_event_data"
            android:textSize="11sp"
            android:textColor="#556677"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="6dp" />

        <!-- View Waiting List -->
        <LinearLayout
            android:id="@+id/rowViewWaitingList"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_row_item"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="2dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                app:tint="#7A8FA6"
                android:layout_marginEnd="14dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_view_waiting_list"
                android:textSize="15sp"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvWaitingListRowCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#556677"
                android:layout_marginEnd="6dp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#556677" />

        </LinearLayout>

        <!-- View Entrant Map -->
        <LinearLayout
            android:id="@+id/rowViewEntrantMap"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_row_item"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="2dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_mapmode"
                app:tint="#7A8FA6"
                android:layout_marginEnd="14dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_view_entrant_map"
                android:textSize="15sp"
                android:textColor="#FFFFFF" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#556677" />

        </LinearLayout>

        <!-- View Event QR Code -->
        <LinearLayout
            android:id="@+id/rowViewQrCode"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_row_item"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="#7A8FA6"
                android:layout_marginEnd="14dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_view_qr_code"
                android:textSize="15sp"
                android:textColor="#FFFFFF" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#556677" />

        </LinearLayout>

        <!-- ── SETTINGS ───────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_settings"
            android:textSize="11sp"
            android:textColor="#556677"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="6dp" />

        <!-- Edit Event Details -->
        <LinearLayout
            android:id="@+id/rowEditEvent"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_row_item"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="2dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="#7A8FA6"
                android:layout_marginEnd="14dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_edit_event"
                android:textSize="15sp"
                android:textColor="#FFFFFF" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#556677" />

        </LinearLayout>

        <!-- View Cancelled Users -->
        <LinearLayout
            android:id="@+id/rowCancelledUsers"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_row_item"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="32dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#7A8FA6"
                android:layout_marginEnd="14dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_cancelled_users"
                android:textSize="15sp"
                android:textColor="#FFFFFF" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#556677" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>