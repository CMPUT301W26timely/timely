<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0EDE8"
    android:id="@+id/eventDetailActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ── HERO IMAGE AREA ──────────────────────────────────────────── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="300dp">

            <!-- Hero poster image — loaded from Firestore posterUrl via Glide -->
            <ImageView
                android:id="@+id/ivHeroPoster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/bg_hero_image"
                android:contentDescription="@string/decorative_image" />

            <!-- Dark overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#88000000" />

            <!-- Top bar: back + progress -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="36dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_media_previous"
                    android:background="@drawable/bg_icon_btn_light"
                    android:contentDescription="@string/back_button_desc" />

                <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

                <ProgressBar
                    android:id="@+id/detailProgressBar"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp" />

            </LinearLayout>

            <!-- Bottom of hero: status badge + title + date + location -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_gravity="bottom"
                android:padding="16dp">

                <!-- Status badge -->
                <TextView
                    android:id="@+id/tvDetailStatusBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#111111"
                    android:background="@drawable/bg_status_badge_open"
                    android:layout_marginBottom="8dp" />

                <!-- Event title -->
                <TextView
                    android:id="@+id/tvDetailTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    android:layout_marginBottom="6dp" />

                <!-- Date row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_menu_today"
                        app:tint="#CCCCCC"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="@string/decorative_image" />

                    <TextView
                        android:id="@+id/tvDetailDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@android:color/white" />

                </LinearLayout>

                <!-- Location row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@android:drawable/ic_menu_mylocation"
                        app:tint="#CCCCCC"
                        android:layout_marginEnd="6dp"
                        android:contentDescription="@string/decorative_image" />

                    <TextView
                        android:id="@+id/tvDetailLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@android:color/white" />

                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- ── DESCRIPTION ──────────────────────────────────────────────── -->
        <TextView
            android:id="@+id/tvDetailDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="4dp"
            android:textSize="13sp"
            android:textColor="@color/textSecondary"
            android:lineSpacingMultiplier="1.4" />

        <!-- ── CAPACITY ROW ──────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cost_label"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA"
                    android:textAllCaps="true" />
                <TextView
                    android:id="@+id/tvEventCost"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$0.00"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111111" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/max_capacity_label"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA"
                    android:textAllCaps="true" />
                <TextView
                    android:id="@+id/tvMaxCapacity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111111" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/waitlist_capacity_label"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA"
                    android:textAllCaps="true" />
                <TextView
                    android:id="@+id/tvWinnersCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#111111" />
            </LinearLayout>

        </LinearLayout>

        <!-- ── STAT CARDS ───────────────────────────────────────────────── -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:padding="16dp"
            android:useDefaultMargins="true">

            <!-- Waiting List -->
            <androidx.cardview.widget.CardView
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_marginEnd="6dp"
                android:layout_marginBottom="8dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:padding="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/stat_waiting_list"
                            android:textSize="11sp"
                            android:textColor="#AAAAAA"
                            android:textAllCaps="true" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_menu_my_calendar"
                            app:tint="#6A9E6A"
                            android:contentDescription="@string/decorative_image" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvWaitingCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#111111" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Invited -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardInvited"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_marginStart="6dp"
                android:layout_marginBottom="8dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:padding="12dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/stat_invited"
                            android:textSize="11sp"
                            android:textColor="#AAAAAA"
                            android:textAllCaps="true" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_dialog_email"
                            app:tint="#4A7A4A"
                            android:contentDescription="@string/decorative_image" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvInvitedCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#111111" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Enrolled -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardEnrolled"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:padding="12dp">
                    <LinearLayout
                        android:id="@+id/boxViewEnrolled"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/stat_enrolled"
                            android:textSize="11sp"
                            android:textColor="#AAAAAA"
                            android:textAllCaps="true" />
                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@android:drawable/ic_menu_add"
                            app:tint="#4A7A4A"
                            android:contentDescription="@string/decorative_image" />
                    </LinearLayout>
                    <TextView
                        android:id="@+id/tvEnrolledCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="26sp"
                        android:textStyle="bold"
                        android:textColor="#111111" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Cancelled -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCancelled"
                android:layout_width="0dp"
                android:layout_height="80dp"
                android:layout_columnWeight="1"
                android:layout_marginStart="6dp"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="#FFFFFF"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="190dp"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/stat_cancelled"
                            android:textAllCaps="true"
                            android:textColor="#AAAAAA"
                            android:textSize="11sp" />

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:contentDescription="@string/decorative_image"
                            android:src="@android:drawable/ic_delete"
                            app:tint="#CC3333" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvCancelledCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#111111"
                        android:textSize="26sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </GridLayout>

        <!-- ── LOTTERY MANAGEMENT ────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_lottery_management"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="6dp" />

        <!-- Run Lottery Draw -->
        <LinearLayout
            android:id="@+id/rowRunLottery"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_row_item_light"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="2dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_rotate"
                app:tint="#4A7A4A"
                android:layout_marginEnd="14dp"
                android:contentDescription="@string/decorative_image" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_run_lottery"
                android:textSize="15sp"
                android:textColor="#111111" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#CCCCCC"
                android:contentDescription="@string/decorative_image" />

        </LinearLayout>

        <!-- Send Notification -->
        <LinearLayout
            android:id="@+id/rowSendNotification"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_row_item_light"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_popup_reminder"
                app:tint="#CCCCCC"
                android:layout_marginEnd="14dp"
                android:contentDescription="@string/decorative_image" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_send_notification"
                android:textSize="15sp"
                android:textColor="#111111" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#CCCCCC"
                android:contentDescription="@string/decorative_image" />

        </LinearLayout>

        <!-- ── EVENT DATA ─────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_event_data"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="6dp" />

        <!-- View Waiting List -->
        <LinearLayout
            android:id="@+id/rowViewWaitingList"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_row_item_light"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="2dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                app:tint="#CCCCCC"
                android:layout_marginEnd="14dp"
                android:contentDescription="@string/decorative_image" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_view_waiting_list"
                android:textSize="15sp"
                android:textColor="#111111" />

            <TextView
                android:id="@+id/tvWaitingListRowCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="#AAAAAA"
                android:layout_marginEnd="6dp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#CCCCCC"
                android:contentDescription="@string/decorative_image" />

        </LinearLayout>

        <!-- View Entrant Map -->
        <LinearLayout
            android:id="@+id/rowViewEntrantMap"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_row_item_light"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="2dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_mapmode"
                app:tint="#CCCCCC"
                android:layout_marginEnd="14dp"
                android:contentDescription="@string/decorative_image" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_view_entrant_map"
                android:textSize="15sp"
                android:textColor="#111111" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#CCCCCC"
                android:contentDescription="@string/decorative_image" />

        </LinearLayout>

        <!-- View Event QR Code -->
        <LinearLayout
            android:id="@+id/rowViewQrCode"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_row_item_light"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_camera"
                app:tint="#CCCCCC"
                android:layout_marginEnd="14dp"
                android:contentDescription="@string/decorative_image" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_view_qr_code"
                android:textSize="15sp"
                android:textColor="#111111" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#CCCCCC"
                android:contentDescription="@string/decorative_image" />

        </LinearLayout>

        <!-- ── SETTINGS ───────────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/section_settings"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="6dp" />

        <!-- Edit Event Details -->
        <LinearLayout
            android:id="@+id/rowEditEvent"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_row_item_light"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="2dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="#CCCCCC"
                android:layout_marginEnd="14dp"
                android:contentDescription="@string/decorative_image" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_edit_event"
                android:textSize="15sp"
                android:textColor="#111111" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#CCCCCC"
                android:contentDescription="@string/decorative_image" />

        </LinearLayout>

        <!-- Assign Co-Organizer (US 02.09.01) -->
        <LinearLayout
            android:id="@+id/rowAssignCoOrganizer"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_row_item_light"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="2dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_add"
                app:tint="#CCCCCC"
                android:layout_marginEnd="14dp"
                android:contentDescription="@string/decorative_image" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_assign_co_organizer"
                android:textSize="15sp"
                android:textColor="#111111" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#CCCCCC"
                android:contentDescription="@string/decorative_image" />

        </LinearLayout>

        <!-- Current co-organizer display — hidden until one is assigned -->
        <LinearLayout
            android:id="@+id/layoutCoOrganizerDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="2dp"
            android:background="#FFF8F0"
            android:visibility="gone">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_menu_info_details"
                app:tint="#4A7A4A"
                android:layout_marginEnd="10dp"
                android:contentDescription="@string/decorative_image" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Co-organizer: "
                android:textSize="13sp"
                android:textColor="#555555" />

            <TextView
                android:id="@+id/tvCoOrganizerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#4A7A4A" />

        </LinearLayout>

        <!-- View Cancelled Users -->
        <LinearLayout
            android:id="@+id/rowCancelledUsers"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_row_item_light"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="32dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#CCCCCC"
                android:layout_marginEnd="14dp"
                android:contentDescription="@string/decorative_image" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/row_cancelled_users"
                android:textSize="15sp"
                android:textColor="#111111" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@android:drawable/ic_media_next"
                app:tint="#CCCCCC"
                android:contentDescription="@string/decorative_image" />

        </LinearLayout>
        <!-- ═══════════════════════════════════════════════════════════════════════
             COMMENTS SECTION  (US 02.08.01 / US 02.08.02)
             Add this block BEFORE the closing </LinearLayout></ScrollView> tags
             at the very bottom of activity_event_detail.xml.
             ═══════════════════════════════════════════════════════════════════════ -->

        <!-- Section header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="COMMENTS"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="8dp"
            android:paddingBottom="6dp" />

        <!-- Comment view buttons card (US 02.08.02) -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center">

                <!-- View entrant comments -->
                <Button
                    android:id="@+id/btnViewEntrantComments"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="6dp"
                    android:text="View Entrant Comments"
                    android:textSize="12sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#4A7A4A"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

                <!-- View my (organizer) comments -->
                <Button
                    android:id="@+id/btnViewMyComments"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="View My Comments"
                    android:textSize="12sp"
                    android:textColor="#4A7A4A"
                    android:backgroundTint="#E8F0E8"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Post new comment card -->
        <androidx.cardview.widget.CardView
            xmlns:app="http://schemas.android.com/apk/res-auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <!-- Text input for new comment -->
                <EditText
                    android:id="@+id/etNewComment"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Write a comment…"
                    android:textSize="14sp"
                    android:textColor="#222222"
                    android:background="@drawable/bg_input_field"
                    android:padding="10dp"
                    android:maxLines="4"
                    android:inputType="textMultiLine|textCapSentences"
                    android:imeOptions="actionDone"
                    android:layout_marginEnd="8dp" />

                <!-- Send button -->
                <Button
                    android:id="@+id/btnPostComment"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Post"
                    android:textSize="13sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#4A7A4A"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>
    </LinearLayout>


</ScrollView>