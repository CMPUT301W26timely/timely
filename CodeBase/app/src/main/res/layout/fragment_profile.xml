<?xml version="1.0" encoding="utf-8"?>
<!-- Profile tab layout -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#06152B">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile &amp; History"
            android:textColor="@android:color/white"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/textViewProfileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No name set"
            android:textColor="@android:color/white"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/textViewDeviceId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#9FB3D1"
            android:layout_marginBottom="20dp" />

        <TextView
            android:id="@+id/textViewEditProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit All"
            android:textColor="#4EA1FF"
            android:textStyle="bold"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PERSONAL INFORMATION"
            android:textColor="#9FB3D1"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/textViewProfileEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No email set"
            android:textColor="@android:color/white"
            android:padding="16dp"
            android:background="#0B1E3A"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/textViewProfilePhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No phone number set"
            android:textColor="@android:color/white"
            android:padding="16dp"
            android:background="#0B1E3A" />
    </LinearLayout>
</ScrollView>