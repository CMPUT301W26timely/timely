<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:foreground="?attr/selectableItemBackground"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp">

        <!-- Thumbnail -->
        <ImageView
            android:id="@+id/ivEventThumbnail"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_event_thumbnail"
            android:scaleType="centerCrop"
            android:clipToOutline="true"
            android:layout_marginEnd="14dp"
            android:contentDescription="@string/event_poster_desc" />

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Title -->
            <TextView
                android:id="@+id/tvEventItemTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:letterSpacing="-0.01"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginBottom="3dp" />

            <!-- Date -->
            <TextView
                android:id="@+id/tvEventItemDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#AAAAAA"
                android:layout_marginBottom="8dp" />

            <!-- Status badge — pill style -->
            <TextView
                android:id="@+id/tvEventStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:textSize="9sp"
                android:textStyle="bold"
                android:letterSpacing="0.06"
                android:layout_marginBottom="8dp" />

            <!-- Stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    app:tint="#CCCCCC"
                    android:contentDescription="@string/stat_waiting_list"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tvWaitingCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA"
                    android:layout_marginEnd="14dp" />

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@android:drawable/ic_menu_rotate"
                    app:tint="#CCCCCC"
                    android:contentDescription="@string/stat_drawn"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tvSelectedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="#AAAAAA" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>