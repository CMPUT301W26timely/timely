<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_assign_co_organizer.xml
    Uses NestedScrollView + RadioGroup to avoid ListView rendering artifacts in dialogs.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF"
    android:weightSum="1">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Assign Co-Organizer"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#111111"
        android:layout_marginBottom="4dp" />

    <!-- Event name subtitle -->
    <TextView
        android:id="@+id/tvCoOrgDialogEventTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#888888"
        android:layout_marginBottom="12dp" />

    <!-- Instruction -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select an entrant to assign as co-organizer. Only one co-organizer is allowed per event."
        android:textSize="13sp"
        android:textColor="#555555"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/etCoOrgSearch"
        style="@style/Widget.CodeBase.EditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:hint="Search entrants"
        android:imeOptions="actionSearch"
        android:inputType="text"
        android:maxLines="1" />

    <!-- Loading spinner -->
    <ProgressBar
        android:id="@+id/coOrgProgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

    <!-- Warning / empty state -->
    <TextView
        android:id="@+id/tvCoOrgEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone" />

    <!-- NestedScrollView prevents ListView rendering artifacts -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:minHeight="80dp"
        android:maxHeight="240dp"
        android:overScrollMode="never"
        android:fillViewport="true">

        <RadioGroup
            android:id="@+id/rgCoOrgEntrants"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />

    </androidx.core.widget.NestedScrollView>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btnCoOrgCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cancel"
            android:textSize="14sp"
            android:textColor="#555555"
            android:backgroundTint="#E0E0E0"
            android:layout_marginEnd="12dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp" />

        <Button
            android:id="@+id/btnCoOrgAssign"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Assign"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4A7A4A"
            android:paddingStart="20dp"
            android:paddingEnd="20dp" />

    </LinearLayout>

</LinearLayout>
