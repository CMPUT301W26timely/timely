<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pageBg">

    <!-- ── TOP BAR ──────────────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp"
        android:background="@color/pageBg">

        <ImageButton
            android:id="@+id/btnBackWaitingList"
            style="@style/Widget.CodeBase.BackButton"
            android:contentDescription="@string/back_button_desc" />

        <TextView
            android:id="@+id/tvWaitingListTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Waiting List"
            style="@style/TextAppearance.CodeBase.PageTitleCompact"
            android:gravity="center"
            android:layout_marginEnd="42dp" />

    </LinearLayout>

    <!-- ── COUNT BADGE ──────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvWaitingListCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="10dp"
        android:textSize="13sp"
        android:textColor="@color/textMuted" />

    <!-- ── PROGRESS BAR ──────────────────────────────────────────────────── -->
    <ProgressBar
        android:id="@+id/waitingListProgressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:visibility="gone" />

    <!-- ── EMPTY STATE ───────────────────────────────────────────────────── -->
    <TextView
        android:id="@+id/tvWaitingListEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No entrants on the waiting list yet."
        android:textSize="14sp"
        android:textColor="@color/textSecondary"
        android:gravity="center"
        android:paddingTop="40dp"
        android:visibility="gone" />

    <!-- ── LIST ─────────────────────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWaitingList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="4dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false" />

</LinearLayout>
