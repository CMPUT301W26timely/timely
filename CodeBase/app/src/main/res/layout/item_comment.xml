<?xml version="1.0" encoding="utf-8"?>
<!--
    item_comment.xml
    Layout for a single comment row in the organizer's event detail comments section.
    Used by OrganizerCommentAdapter.

    Displays:
      - A circular avatar placeholder (author initial)
      - Author name + timestamp on the right
      - Comment body text below
      - A delete (trash) icon button aligned to the far right
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="16dp"
    android:paddingEnd="8dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:gravity="top">

    <!-- Avatar circle with author initial -->
    <TextView
        android:id="@+id/tvCommentAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:text="O"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:background="@drawable/bg_avatar_circle"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="2dp" />

    <!-- Comment content: name + time + text -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Row: author name + timestamp -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvCommentAuthor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tvCommentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#AAAAAA" />

        </LinearLayout>

        <!-- Comment body -->
        <TextView
            android:id="@+id/tvCommentText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#444444"
            android:layout_marginTop="3dp"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

    <!-- Delete button -->
    <ImageButton
        android:id="@+id/btnDeleteComment"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@android:drawable/ic_menu_delete"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Delete comment"
        android:layout_marginStart="4dp"
        android:layout_marginTop="0dp"
        android:tint="#CCCCCC" />

</LinearLayout>